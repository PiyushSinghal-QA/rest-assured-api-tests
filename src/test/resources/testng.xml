<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="REST Assured API Test Suite" verbose="1" parallel="classes" thread-count="3">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="User Management Tests">
        <classes>
            <class name="com.piyushsinghal.api.tests.GetUsersTest"/>
            <class name="com.piyushsinghal.api.tests.CreateUserTest"/>
            <class name="com.piyushsinghal.api.tests.UpdateDeleteUserTest"/>
        </classes>
    </test>

    <test name="Authentication Tests">
        <classes>
            <class name="com.piyushsinghal.api.tests.AuthenticationTest"/>
        </classes>
    </test>

</suite>
